/*  LC - 76. Minimum Window Substring
    Level - Hard
    Pattern - Sliding Window
    Approach - A window is VALID if:
                All characters in t are present in the window with their required frequency
                If that's true, we can try to shrink the window from left to find the minimum length
    Time Complexity - O(m+n)
    Space Complexity - O(m+n) where m is the length of t and n is the length of s
*/

public class minimumwindowsubstring {

    public String minWindow(String s, String t) {

        if (s.length() < t.length())
            return "";

        int[] need = new int[128];

        for (char c : t.toCharArray())
            need[c]++;

        int left = 0;
        int required = t.length();

        int minLen = Integer.MAX_VALUE;
        int start = 0;

        for (int right = 0; right < s.length(); right++) {

            char ch = s.charAt(right);

            if (need[ch] > 0)
                required--;

            need[ch]--;

            while (required == 0) {

                if (right - left + 1 < minLen) {
                    minLen = right - left + 1;
                    start = left;
                }

                char leftChar = s.charAt(left);

                need[leftChar]++;

                if (need[leftChar] > 0)
                    required++;

                left++;
            }
        }

        return minLen == Integer.MAX_VALUE
                ? ""
                : s.substring(start, start + minLen);
    }
}